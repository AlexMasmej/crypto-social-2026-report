{
  "rewrites": [
    { "source": "/", "destination": "/site/index.html" }
  ],
  "headers": [
    {
      "source": "/(raw|wiki)/(.*).md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
